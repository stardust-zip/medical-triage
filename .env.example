# ANTHROPIC_API_KEY=your_key_here # Coding keY
OPENAI_API_KEY=your_key_here
# GEMINI_API_KEY=your_key_here

LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST="https://cloud.langfuse.com"

DATABASE_URL=postgresql://postgres.[your-project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Phase 1: Gateway + Identity + Tenancy ---
# Shared secret api-gateway attaches to every proxied request; the FastAPI
# backend refuses anything without it (see src/context.py). Also used by
# gateway <-> identity-service internal calls (INTERNAL_SHARED_SECRET).
GATEWAY_SHARED_SECRET=change-me-to-a-random-string
INTERNAL_SHARED_SECRET=change-me-to-a-different-random-string

# HS256 secret Supabase Auth signs access tokens with (Project Settings ->
# API -> JWT Secret). api-gateway verifies staff bearer tokens against this.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Secret api-gateway uses to sign/verify anonymous patient-session tokens
# (POST /api/v1/session/anonymous). Not shared with any external provider.
PATIENT_SESSION_SECRET=change-me-to-another-random-string
