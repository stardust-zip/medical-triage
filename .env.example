# ANTHROPIC_API_KEY=your_key_here # Coding keY
OPENAI_API_KEY=your_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMS=1536
# GEMINI_API_KEY=your_key_here

LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST="https://cloud.langfuse.com"

# Local Docker Compose overrides DATABASE_URL for app containers. Use this
# value when running backend processes directly on your host machine.
DATABASE_URL=postgresql://triageos_app:triageos_app_password@localhost:5432/triageos

# Used by scripts/migrate.py. In production/CI this should be a privileged
# migration role; application services should still use DATABASE_URL above.
ADMIN_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/triageos
APP_DB_USER=triageos_app
APP_DB_PASSWORD=triageos_app_password

# Docker Compose uses service DNS ("db") instead of host localhost.
COMPOSE_DATABASE_URL=postgresql://triageos_app:triageos_app_password@db:5432/triageos
COMPOSE_ADMIN_DATABASE_URL=postgresql://postgres:postgres@db:5432/triageos
POSTGRES_DB=triageos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

GATEWAY_SHARED_SECRET=change-me-to-a-random-string
INTERNAL_SHARED_SECRET=change-me-to-a-different-random-string

# queue-service (Phase 3) / scheduling-service (Phase 4). Defaults already
# match Docker Compose's service DNS/port; only needed here if you're
# running processes directly on the host instead of via `docker compose up`.
QUEUE_SERVICE_URL=http://localhost:8083
SCHEDULING_SERVICE_URL=http://localhost:8084

STAFF_SESSION_SECRET=change-me-to-yet-another-random-string

PATIENT_SESSION_SECRET=change-me-to-another-random-string

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ORG_SLUG=evergreen-demo
